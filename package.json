{
  "name": "sankofa-express",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others \"node server/socket-server.js\" \"next dev --webpack\"",
    "dev:turbo": "concurrently --kill-others \"node server/socket-server.js\" \"next dev\"",
    "dev:realtime": "node server/socket-server.js",
    "build": "prisma generate && next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "6.14.0",
    "@types/nodemailer": "^8.0.1",
    "clsx": "^2.1.1",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "6.14.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
